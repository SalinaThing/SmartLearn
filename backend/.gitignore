# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor / OS artifacts
.vscode/
.idea/
*.swp
*.swo

# Logs
logs/
*.log

# TypeScript
*.tsbuildinfo
